{
  "name": "daf-focus",
  "version": "0.1.0",
  "private": true,
  "description": "AI-first TestDaF digital trainer scaffold",
  "type": "commonjs",
  "scripts": {
    "dev": "next dev",
    "build:web": "next build",
    "build:core": "tsc -p tsconfig.lib.json",
    "build": "npm run build:core && npm run build:web",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit && tsc -p tsconfig.json --noEmit",
    "test": "npm run build:core && node --import tsx --test tests/*.test.ts tests/*.test.cjs",
    "verify": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@fontsource/plus-jakarta-sans": "^5.1.1",
    "next": "^15.2.4",
    "openai": "^4.104.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
